<div id="<%= dom_id lease %>">
  <p>
    <strong>Unit:</strong>
    <%= lease.unit_id %>
  </p>

  <p>
    <strong>Tenant:</strong>
    <%= lease.tenant_id %>
  </p>

  <p>
    <strong>Price:</strong>
    <%= lease.price %>
  </p>

  <p>
    <strong>Duration:</strong>
    <%= lease.duration %>
  </p>

  <p>
    <strong>Due day:</strong>
    <%= lease.due_day %>
  </p>

  <p>
    <strong>Active:</strong>
    <%= lease.active %>
  </p>

</div>
